-- Compare two version strings (e.g., "2.0.0" vs "2.1.0")
function Library:CompareVersion(otherVersion)
	local function parseVersion(v)
		local parts = {}
		for part in v:gmatch("%d+") do
			table.insert(parts, tonumber(part))
		end
		return parts
	end
	local v1 = parseVersion(self.Version)
	local v2 = parseVersion(otherVersion)
	for i = 1, math.max(#v1, #v2) do
		local a = v1[i] or 0
		local b = v2[i] or 0
		if a > b then return 1 end
		if a < b then return -1 end
	end
	return 0
end

-- Check if the library meets a minimum version requirement
function Library:MeetsVersion(minVersion)
	return self:CompareVersion(minVersion) >= 0
end

return Library

