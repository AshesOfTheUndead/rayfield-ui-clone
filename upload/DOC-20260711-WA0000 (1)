		-- ============================================================
		-- CreateSlider — draggable value selector
		-- ============================================================
		function tab:CreateSlider(cfg)
			cfg = cfg or {}
			local nameText  = cfg.Name or "Slider"
			local range     = cfg.Range or { 0, 100 }
			local minVal    = range[1]
			local maxVal    = range[2]
			local increment = cfg.Increment or 1
			local suffix    = cfg.Suffix or ""
			local callback  = cfg.Callback
			local value     = clamp(cfg.CurrentValue or minVal, minVal, maxVal)

			local holder, hStroke = makeHolder(52)
			local lbl = Instance.new("TextLabel")
			lbl.Name = "Label"
			lbl.Size = UDim2.new(1, -80, 0, 18)
			lbl.Position = UDim2.new(0, 14, 0, 6)
			lbl.BackgroundTransparency = 1
