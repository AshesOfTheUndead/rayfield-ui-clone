-- Validate a window configuration table
function Library:ValidateWindowConfig(cfg)
	cfg = cfg or {}
	local errors = {}
	local warnings = {}

	if cfg.Name and type(cfg.Name) ~= "string" then
		table.insert(errors, "Name must be a string")
	end
	if cfg.Subtitle and type(cfg.Subtitle) ~= "string" then
		table.insert(warnings, "Subtitle should be a string")
	end
	if cfg.Theme and not Themes[cfg.Theme] and type(cfg.Theme) ~= "table" then
		table.insert(errors, "Theme must be a valid theme name or theme table")
	end
	if cfg.Size then
		if type(cfg.Size) ~= "table" or not cfg.Size.X or not cfg.Size.Y then
			table.insert(errors, "Size must be a table with X and Y values")
		end
	end
	if cfg.ToggleUIKeybind and typeof(cfg.ToggleUIKeybind) ~= "EnumItem" then
		table.insert(warnings, "ToggleUIKeybind should be an Enum.KeyCode")
	end

	return #errors == 0, errors, warnings
end

-- Validate an element configuration table
function Library:ValidateElementConfig(elementType, cfg)
	cfg = cfg or {}
	local errors = {}
	local required = {
		Button = { "Name" },
		Toggle = { "Name" },
		Slider = { "Name" },
		Input = { "Name" },
		Dropdown = { "Name" },
		Keybind = { "Name" },
		ColorPicker = { "Name" },
		ProgressBar = { "Name" },
		Label = {},
		Paragraph = {},
		Section = {},
		Divider = {},
		Image = {},
		Accordion = {},
		Bindable = { "Name" },
		MultiButton = {},
		Spacer = {},
	}
	local reqs = required[elementType] or {}
	for _, field in ipairs(reqs) do
		if not cfg[field] then
			table.insert(errors, elementType .. ": " .. field .. " is required")
		end
	end
	return #errors == 0, errors
end

