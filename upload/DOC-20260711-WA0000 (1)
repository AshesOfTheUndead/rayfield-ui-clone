-- ============================================================

-- Safely create an element, returns nil on failure instead of erroring
function Library:SafeCreate(elementFn, ...)
	local ok, result = pcall(elementFn, ...)
	if ok then
		return result
	else
		warn("[RezurXLib] SafeCreate failed: " .. tostring(result))
		return nil
	end
end

-- Batch create multiple elements safely
function Library:BatchCreate(tab, elements)
	local results = {}
	for _, elem in ipairs(elements) do
		local fn = elem[1]
		local args = elem[2] or {}
		local ok, result = pcall(function()
			return tab[fn](tab, args)
		end)
		if ok then
			table.insert(results, result)
		else
			warn("[RezurXLib] BatchCreate failed for " .. tostring(fn) .. ": " .. tostring(result))
			table.insert(results, nil)
		end
	end
	return results
end

