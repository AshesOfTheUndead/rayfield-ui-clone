-- Deep copy a table (useful for saving/loading configurations)
function Library:DeepCopy(orig)
	local copy
	if type(orig) == "table" then
		copy = {}
		for orig_key, orig_value in next, orig, nil do
			copy[self:DeepCopy(orig_key)] = self:DeepCopy(orig_value)
		end
		setmetatable(copy, self:DeepCopy(getmetatable(orig)))
	else
		copy = orig
	end
	return copy
end

-- Serialize a table to a JSON string (best-effort)
function Library:Serialize(data)
	local ok, result = pcall(function()
		return HttpService:JSONEncode(data)
	end)
	if ok then
		return result
	else
		warn("[RezurXLib] Serialize failed: " .. tostring(result))
		return nil
	end
end

-- Deserialize a JSON string to a table
function Library:Deserialize(jsonStr)
	if type(jsonStr) ~= "string" then return nil end
	local ok, result = pcall(function()
		return HttpService:JSONDecode(jsonStr)
	end)
	if ok then
		return result
	else
		warn("[RezurXLib] Deserialize failed: " .. tostring(result))
		return nil
	end
end

-- Save all current flag values to a serializable table
function Library:SaveConfiguration()
	local config = {}
	for flag, obj in pairs(self.Flags) do
		if obj.CurrentValue ~= nil then
			config[flag] = obj.CurrentValue
		elseif obj.CurrentKeybind ~= nil then
			config[flag] = keyName(obj.CurrentKeybind)
		elseif obj.CurrentColor ~= nil then
			local c = obj.CurrentColor
			config[flag] = { R = c.R, G = c.G, B = c.B }
		elseif obj.CurrentOption ~= nil then
			config[flag] = obj.CurrentOption
		end
	end
	return config
end

-- Load configuration values back into flagged elements
function Library:LoadConfiguration(config)
	if type(config) ~= "table" then
		warn("[RezurXLib] LoadConfiguration expects a table")
		return
	end
	for flag, value in pairs(config) do
		local obj = self.Flags[flag]
		if obj then
			pcall(function()
				if obj.Set then
					if type(value) == "table" and value.R then
						-- Color value
						obj:Set(Color3.new(value.R, value.G, value.B))
					elseif type(value) == "string" and value:match("^%u[%u%d]+$") then
						-- KeyCode name
						local ok, kc = pcall(function()
							return Enum.KeyCode[value]
						end)
						if ok and kc then obj:Set(kc) end
					else
						obj:Set(value)
					end
				end
			end)
		end
	end
end

-- Get information about all flagged elements
function Library:GetFlagInfo()
	local info = {}
	for flag, obj in pairs(self.Flags) do
		info[flag] = {
			Type = type(obj),
			HasSet = obj.Set ~= nil,
			HasGet = obj.Get ~= nil,
		}
	end
	return info
end

-- Check if a flag exists
function Library:HasFlag(flag)
	return self.Flags[flag] ~= nil
end

-- Get the value of a specific flag
function Library:GetFlag(flag)
	local obj = self.Flags[flag]
	if obj then
		if obj.CurrentValue ~= nil then
			return obj.CurrentValue
		elseif obj.CurrentColor ~= nil then
			return obj.CurrentColor
		elseif obj.CurrentKeybind ~= nil then
			return obj.CurrentKeybind
		elseif obj.CurrentOption ~= nil then
			return obj.CurrentOption
		end
	end
	return nil
end

