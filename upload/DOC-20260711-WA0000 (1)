		-- ============================================================
		-- CreateDropdown — selectable options list
		-- Supports multi-select, search/filter, scrollable lists.
		-- ============================================================
		function tab:CreateDropdown(cfg)
			cfg = cfg or {}
			local nameText = cfg.Name or "Dropdown"
			local options  = cfg.Options or {}
			local multi    = cfg.MultipleOptions == true
			local callback = cfg.Callback
			local searchable = cfg.Searchable == true

			local selected = {}
			do
				local cur = cfg.CurrentOption
				if type(cur) == "table" then
					for _, o in ipairs(cur) do selected[o] = true end
				elseif cur ~= nil then
					selected[cur] = true
				elseif not multi and options[1] then
					selected[options[1]] = true
				end
			end

			local holder, hStroke = makeHolder(42)
			local lbl = Instance.new("TextLabel")
			lbl.Name = "Label"
			lbl.Size = UDim2.new(1, -38, 1, 0)
