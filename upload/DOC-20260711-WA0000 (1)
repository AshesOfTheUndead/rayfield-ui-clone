			arrow.TextSize = 12
			arrow.TextColor3 = C.muted
			arrow.Text = "\u{25BE}"
			arrow.Parent = holder

			local obj = {}
			local function selectionList()
				local out = {}
				for _, o in ipairs(options) do
					if selected[o] then table.insert(out, o) end
				end
				return out
			end
			local function displayText()
				local sel = selectionList()
				if #sel == 0 then return nameText .. " \u{00B7} \u{2014}" end
				if multi then
					if #sel <= 2 then
						return nameText .. " \u{00B7} " .. table.concat(sel, ", ")
					end
					return nameText .. " \u{00B7} " .. #sel .. " selected"
				end
				return nameText .. " \u{00B7} " .. sel[1]
			end
			local function refreshLabel()
				lbl.Text = displayText()
			end
			refreshLabel()

