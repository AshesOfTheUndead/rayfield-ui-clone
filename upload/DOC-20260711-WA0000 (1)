-- Smooth number animation (tween a number value over time)
function Library:TweenNumber(startVal, endVal, duration, callback)
	duration = duration or 0.5
	local startTime = tick()
	local connection
	connection = RunService.Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		local progress = math.min(elapsed / duration, 1)
		-- Ease out quad
		progress = 1 - (1 - progress) * (1 - progress)
		local current = startVal + (endVal - startVal) * progress
		pcall(callback, current)
		if elapsed >= duration then
			connection:Disconnect()
			pcall(callback, endVal)
		end
	end)
	return connection
end

-- Pulse animation for any GUI object
function Library:PulseObject(obj, minScale, maxScale, duration)
	minScale = minScale or 1
	maxScale = maxScale or 1.05
	duration = duration or 0.8
	local direction = 1
	local function pulse()
		local target = direction == 1 and maxScale or minScale
		local tween = Tween(obj, TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{ Size = UDim2.new(target, 0, target, 0) })
		if tween then
			tween.Completed:Connect(function()
				direction = -direction
				pulse()
			end)
		end
	end
	pulse()
end

