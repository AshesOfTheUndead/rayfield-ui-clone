-- Animate an element's transparency for fade-in/fade-out effects
function Library:FadeIn(obj, duration)
	duration = duration or 0.3
	obj.BackgroundTransparency = 1
	Tween(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 0 })
end

function Library:FadeOut(obj, duration)
	duration = duration or 0.3
	Tween(obj, TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 })
end

-- Slide an element in from a direction
function Library:SlideIn(obj, direction, distance, duration)
	direction = direction or "Left"
	distance = distance or 50
	duration = duration or 0.35
	local goal = {}
	if direction == "Left" then
		goal.Position = UDim2.new(obj.Position.X.Scale, obj.Position.X.Offset + distance, obj.Position.Y.Scale, obj.Position.Y.Offset)
	elseif direction == "Right" then
		goal.Position = UDim2.new(obj.Position.X.Scale, obj.Position.X.Offset - distance, obj.Position.Y.Scale, obj.Position.Y.Offset)
	elseif direction == "Up" then
		goal.Position = UDim2.new(obj.Position.X.Scale, obj.Position.X.Offset, obj.Position.Y.Scale, obj.Position.Y.Offset + distance)
	elseif direction == "Down" then
		goal.Position = UDim2.new(obj.Position.X.Scale, obj.Position.X.Offset, obj.Position.Y.Scale, obj.Position.Y.Offset - distance)
	end
	obj.BackgroundTransparency = 1
	Tween(obj, TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.Out), goal)
end

-- Count the total number of GUI descendants in a window
function Library:CountElements(window)
	local count = 0
	local function countDescendants(obj)
		for _, child in ipairs(obj:GetDescendants()) do
			count = count + 1
			countDescendants(child)
		end
	end
	if window and window._janitor then
		-- Best effort: we cannot directly access the frame,
		-- but windows can expose this if needed
	end
	return count
end

-- Export the complete theme table for external use
function Library:ExportThemes()
	return Themes
end

-- Get a specific theme by name
function Library:GetTheme(name)
	return Themes[name]
end

-- Register a custom theme
function Library:RegisterTheme(name, themeTable)
	if type(themeTable) ~= "table" then
		warn("[RezurXLib] Theme table required for RegisterTheme")
		return
	end
	-- Validate required fields
	local requiredFields = { "bg", "panel", "accent", "text", "border" }
	for _, field in ipairs(requiredFields) do
		if not themeTable[field] then
			warn("[RezurXLib] Theme missing required field: " .. field)
			return
		end
	end
	Themes[name] = themeTable
end

-- Shake effect for error feedback on an element
function Library:ShakeObject(obj, intensity)
	intensity = intensity or 6
	local originalPos = obj.Position
	local shakeCount = 0
	local maxShakes = 8
	local connection
	connection = RunService.Heartbeat:Connect(function()
		shakeCount = shakeCount + 1
		local offsetX = math.random(-intensity, intensity)
		local offsetY = math.random(-intensity // 2, intensity // 2)
		obj.Position = UDim2.new(
			originalPos.X.Scale, originalPos.X.Offset + offsetX,
			originalPos.Y.Scale, originalPos.Y.Offset + offsetY)
		if shakeCount >= maxShakes then
			connection:Disconnect()
			obj.Position = originalPos
		end
	end)
end

