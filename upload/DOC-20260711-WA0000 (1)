	-- ============================================================
	-- THEME API
	-- ============================================================
	function Window:ModifyTheme(theme)
		local set = (type(theme) == "table") and theme or Themes[theme]
		if not set then
			warn("[RezurXLib] Unknown theme: " .. tostring(theme))
			return
		end
		for k, v in pairs(set) do C[k] = v end
		C.borderAcc = C.accent
		for _, fn in ipairs(ThemeRefreshers) do
			pcall(fn)
		end
	end

	function Window:GetThemes()
		local out = {}
		for name, _ in pairs(Themes) do table.insert(out, name) end
		return out
	end

	function Window:SetTitle(text)
		logo.Text = text or ""
	end

	function Window:SetSubtitle(text)
		subLbl.Text = text or ""
	end

	function Window:Destroy()
		setHidden(true)
		closeCurrentPopup()
		WindowJanitor:Cleanup()
		for i, w in ipairs(Library._windows) do
			if w == Window then table.remove(Library._windows, i) break end
		end
	end

