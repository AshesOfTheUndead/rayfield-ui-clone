-- ============================================================
-- EVENT SYSTEM — simple pub/sub for cross-element communication
-- ============================================================

Library._events = {}

-- Subscribe to a named event
function Library:On(eventName, callback)
	if not self._events[eventName] then
		self._events[eventName] = {}
	end
	table.insert(self._events[eventName], callback)
	return #self._events[eventName]
end

-- Emit a named event with optional data
function Library:Emit(eventName, ...)
	if self._events[eventName] then
		for _, callback in ipairs(self._events[eventName]) do
			task.spawn(function(...)
				pcall(callback, ...)
			end, ...)
		end
	end
end

-- Remove all listeners for an event
function Library:Off(eventName)
	self._events[eventName] = nil
end

