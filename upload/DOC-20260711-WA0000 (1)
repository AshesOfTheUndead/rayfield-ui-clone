-- Color manipulation utilities for theme creators
function Library:ColorLighten(color, amount)
	amount = amount or 0.2
	local h, s, v = color:ToHSV()
	return Color3.fromHSV(h, s, math.min(v + amount, 1))
end

function Library:ColorDarken(color, amount)
	amount = amount or 0.2
	local h, s, v = color:ToHSV()
	return Color3.fromHSV(h, s, math.max(v - amount, 0))
end

function Library:ColorSaturate(color, amount)
	amount = amount or 0.2
	local h, s, v = color:ToHSV()
	return Color3.fromHSV(h, math.min(s + amount, 1), v)
end

function Library:ColorDesaturate(color, amount)
	amount = amount or 0.2
	local h, s, v = color:ToHSV()
	return Color3.fromHSV(h, math.max(s - amount, 0), v)
end

-- Generate a complete theme from a single accent color
function Library:GenerateTheme(accentColor, name)
