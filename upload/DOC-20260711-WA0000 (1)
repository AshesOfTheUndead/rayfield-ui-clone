	local r, g, b = accentColor.R, accentColor.G, accentColor.B
	return {
		name = name or "Custom",
		bg = Color3.fromRGB(math.max(round(r * 15), 5), math.max(round(g * 15), 5), math.max(round(b * 15), 8)),
		panel = Color3.fromRGB(round(r * 25), round(g * 25), round(b * 25)),
